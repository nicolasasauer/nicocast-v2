# Cargo build artefacts (can be rebuilt from source at any time)
/target/

# Cross-compiled binary extracted by setup.sh (reproducible build artifact)
/nicocast-aarch64

# Cargo credentials (never commit)
.cargo/credentials.toml

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS artefacts
.DS_Store
Thumbs.db

# Logs generated during local development
*.log

# Python bytecode cache
__pycache__/
*.pyc
*.pyo
